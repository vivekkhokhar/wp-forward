# Copy to instance.env and fill in. instance.env is git-ignored (holds your server IP).
export WA_HOST=YOUR_INSTANCE_PUBLIC_IP
export WA_USER=ec2-user
export WA_KEY=$HOME/.ssh/wa-forward.pem
export WA_APP=wa-forward
export WA_SG=YOUR_SECURITY_GROUP_ID
export WA_REGION=ap-south-1
export WA_PROFILE=cli_user
